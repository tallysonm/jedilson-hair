{
  "buildCommand": "pnpm install && pnpm --filter @workspace/barbershop run build",
  "outputDirectory": "artifacts/barbershop/dist",
  "installCommand": "echo 'install runs in buildCommand'",
  "framework": null,
  "functions": {
    "api/[...slug].js": {
      "includeFiles": "api/app.handler.mjs"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...slug]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
