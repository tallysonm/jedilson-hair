{
  "buildCommand": "pnpm --filter @workspace/api-server run build && cp artifacts/api-server/dist/handler/app.handler.mjs api/app.handler.mjs",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/[...slug].js": {
      "includeFiles": "api/app.handler.mjs"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...slug]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
