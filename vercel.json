{
  "buildCommand": "bash vercel-build.sh",
  "outputDirectory": "dist",
  "installCommand": "echo 'install runs in vercel-build.sh'",
  "framework": null,
  "functions": {
    "api/[...slug].js": {
      "includeFiles": "api/app.handler.mjs"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...slug]" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
