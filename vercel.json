{
  "buildCommand": "pnpm install && cd artifacts/barbershop && npx vite build --config vite.config.ts --outDir ../../dist --emptyOutDir",
  "outputDirectory": "dist",
  "installCommand": "echo 'install runs in buildCommand'",
  "framework": null,
  "functions": {
    "api/[...slug].js": {
      "includeFiles": "api/app.handler.mjs"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...slug]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
