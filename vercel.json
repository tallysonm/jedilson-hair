{
  "buildCommand": "echo 'All files pre-built and committed — nothing to compile'",
  "outputDirectory": "dist",
  "installCommand": "echo 'No install needed'",
  "framework": null,
  "functions": {
    "api/[...slug].js": {
      "includeFiles": "api/app.handler.mjs"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...slug]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
